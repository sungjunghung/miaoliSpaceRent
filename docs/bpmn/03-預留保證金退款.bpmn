      <bpmn:outgoing>Flow_P03_14</bpmn:outgoing>
      <bpmn:outgoing>Flow_P03_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N03_S3" name="更新 cashier_processing">
