      <bpmn:outgoing>Flow_P03_18</bpmn:outgoing>
      <bpmn:outgoing>Flow_P03_20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N03_K2" name="保留待辦並重試">
      <bpmn:incoming>Flow_P03_18</bpmn:incoming>
      <bpmn:outgoing>Flow_P03_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N03_S4" name="更新 status=completed">
      <bpmn:incoming>Flow_P03_20</bpmn:incoming>
      <bpmn:outgoing>Flow_P03_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N03_E1" name="退款完成">
      <bpmn:incoming>Flow_P03_21</bpmn:incoming>
    </bpmn:endEvent>
