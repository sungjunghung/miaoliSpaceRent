      <bpmn:incoming>Flow_P03_14</bpmn:incoming>
      <bpmn:outgoing>Flow_P03_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N03_E2" name="退款駁回">
