<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_P04" targetNamespace="http://miaoli.gov.tw/spaceRent/bpmn">
  <bpmn:collaboration id="Collaboration_P04">
    <bpmn:participant id="Participant_P04" name="場館規則設定與發布" processRef="Process_P04" />
  </bpmn:collaboration>
  <bpmn:process id="Process_P04" name="場館規則設定與發布" isExecutable="false">
    <bpmn:laneSet id="LaneSet_P04">
      <bpmn:lane id="Lane04_admin" name="場館管理員">
        <bpmn:flowNodeRef>N04_A1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_A2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_A3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_A4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_A5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_A6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_A7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane04_system" name="系統">
        <bpmn:flowNodeRef>N04_S1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_G1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_S2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_S3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_S4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_S5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_E1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane04_member" name="前台會員">
        <bpmn:flowNodeRef>N04_U1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N04_U2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="N04_A1" name="新增或調整場館規則">
      <bpmn:outgoing>Flow_P04_0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="N04_A2" name="編輯場館基本資料">
      <bpmn:incoming>Flow_P04_0</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_A3" name="設定租借模式與限制">
      <bpmn:incoming>Flow_P04_1</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_A4" name="設定時段與價格">
      <bpmn:incoming>Flow_P04_2</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_A5" name="設定文件需求與附加規則">
      <bpmn:incoming>Flow_P04_3</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_S1" name="驗證規則完整性">
      <bpmn:incoming>Flow_P04_4</bpmn:incoming>
      <bpmn:incoming>Flow_P04_9</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="N04_G1" name="是否有缺漏或衝突">
      <bpmn:incoming>Flow_P04_5</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_P04_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N04_S2" name="回傳錯誤清單">
      <bpmn:incoming>Flow_P04_6</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_A6" name="修正設定">
      <bpmn:incoming>Flow_P04_7</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_A7" name="儲存並發布">
      <bpmn:incoming>Flow_P04_8</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_S3" name="發布規則">
      <bpmn:incoming>Flow_P04_10</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_S4" name="更新前台可租借條件">
      <bpmn:incoming>Flow_P04_11</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_S5" name="更新前台費率與驗證邏輯">
      <bpmn:incoming>Flow_P04_12</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_P04_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N04_E1" name="規則生效">
      <bpmn:incoming>Flow_P04_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="N04_U1" name="查看場地可租模式">
      <bpmn:incoming>Flow_P04_14</bpmn:incoming>
      <bpmn:outgoing>Flow_P04_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N04_U2" name="依新規則進行預約">
      <bpmn:incoming>Flow_P04_15</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_P04_0" sourceRef="N04_A1" targetRef="N04_A2" />
    <bpmn:sequenceFlow id="Flow_P04_1" sourceRef="N04_A2" targetRef="N04_A3" />
