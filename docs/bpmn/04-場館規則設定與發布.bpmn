    <bpmn:sequenceFlow id="Flow_P04_6" name="是" sourceRef="N04_G1" targetRef="N04_S2" />
    <bpmn:sequenceFlow id="Flow_P04_7" sourceRef="N04_S2" targetRef="N04_A6" />
    <bpmn:sequenceFlow id="Flow_P04_8" sourceRef="N04_A6" targetRef="N04_A7" />
    <bpmn:sequenceFlow id="Flow_P04_9" sourceRef="N04_A7" targetRef="N04_S1" />
    <bpmn:sequenceFlow id="Flow_P04_10" name="否" sourceRef="N04_G1" targetRef="N04_S3" />
    <bpmn:sequenceFlow id="Flow_P04_11" sourceRef="N04_S3" targetRef="N04_S4" />
    <bpmn:sequenceFlow id="Flow_P04_12" sourceRef="N04_S4" targetRef="N04_S5" />
    <bpmn:sequenceFlow id="Flow_P04_13" sourceRef="N04_S5" targetRef="N04_E1" />
    <bpmn:sequenceFlow id="Flow_P04_14" name="規則發布通知" sourceRef="N04_S5" targetRef="N04_U1" />
    <bpmn:sequenceFlow id="Flow_P04_15" sourceRef="N04_U1" targetRef="N04_U2" />
  </bpmn:process>
