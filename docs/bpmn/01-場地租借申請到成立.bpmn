      <bpmn:outgoing>Flow_P01_22</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="N01_G3" name="繳費是否逾期">
      <bpmn:incoming>Flow_P01_18</bpmn:incoming>
      <bpmn:outgoing>Flow_P01_19</bpmn:outgoing>
      <bpmn:outgoing>Flow_P01_20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N01_S6" name="狀態更新 cancelled_expired">
      <bpmn:incoming>Flow_P01_20</bpmn:incoming>
      <bpmn:outgoing>Flow_P01_21</bpmn:outgoing>
    </bpmn:task>
