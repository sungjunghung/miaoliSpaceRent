      <bpmn:outgoing>Flow_P01_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N01_S4" name="狀態更新 cancelled_rejected">
      <bpmn:incoming>Flow_P01_10</bpmn:incoming>
      <bpmn:outgoing>Flow_P01_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N01_E2" name="文件逾期取消">
