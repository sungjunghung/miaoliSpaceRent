  <bpmn:collaboration id="Collaboration_P06">
    <bpmn:participant id="Participant_P06" name="繳費核帳與確認" processRef="Process_P06" />
  </bpmn:collaboration>
  <bpmn:process id="Process_P06" name="繳費核帳與確認" isExecutable="false">
    <bpmn:laneSet id="LaneSet_P06">
      <bpmn:lane id="Lane06_member" name="會員">
        <bpmn:flowNodeRef>N06_U2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_U3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane06_system" name="系統">
        <bpmn:flowNodeRef>N06_E0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_S1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_T1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_S3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_S4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_E1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_G1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_S2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_E2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane06_staff" name="承辦">
        <bpmn:flowNodeRef>N06_A1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane06_cashier" name="出納">
        <bpmn:flowNodeRef>N06_C1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_G2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>N06_C2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="N06_E0" name="案件進入 pending_payment">
      <bpmn:outgoing>Flow_P06_0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="N06_S1" name="建立繳費期限">
      <bpmn:incoming>Flow_P06_0</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_1</bpmn:outgoing>
      <bpmn:outgoing>Flow_P06_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="N06_T1" name="繳費截止">
      <bpmn:incoming>Flow_P06_2</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_3</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_N06_T1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="N06_U2" name="提交匯款資訊與證明">
      <bpmn:incoming>Flow_P06_1</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N06_A1" name="檢視案件是否可進入核帳">
      <bpmn:incoming>Flow_P06_4</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N06_S3" name="更新 payment_review">
      <bpmn:incoming>Flow_P06_5</bpmn:incoming>
      <bpmn:incoming>Flow_P06_13</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N06_C1" name="核對匯款金額與帳務資訊">
      <bpmn:incoming>Flow_P06_6</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="N06_G2" name="核帳是否一致">
      <bpmn:incoming>Flow_P06_7</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_8</bpmn:outgoing>
      <bpmn:outgoing>Flow_P06_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N06_S4" name="更新 confirmed">
      <bpmn:incoming>Flow_P06_8</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N06_E1" name="核帳成功">
      <bpmn:incoming>Flow_P06_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="N06_C2" name="標記異常並要求補正">
      <bpmn:incoming>Flow_P06_10</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="N06_G1" name="是否逾期">
      <bpmn:incoming>Flow_P06_3</bpmn:incoming>
      <bpmn:incoming>Flow_P06_11</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_P06_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N06_U3" name="補正匯款資料">
      <bpmn:incoming>Flow_P06_12</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N06_S2" name="更新 cancelled_expired">
      <bpmn:incoming>Flow_P06_14</bpmn:incoming>
      <bpmn:outgoing>Flow_P06_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N06_E2" name="繳費逾期取消">
      <bpmn:incoming>Flow_P06_15</bpmn:incoming>
    </bpmn:endEvent>
