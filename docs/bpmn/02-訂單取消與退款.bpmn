      <bpmn:outgoing>Flow_P02_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="N02_E1" name="取消核准且不退款">
      <bpmn:incoming>Flow_P02_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="N02_S5" name="建立退款案件 booking_cancellation">
