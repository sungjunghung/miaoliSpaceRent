      <bpmn:outgoing>Flow_P02_17</bpmn:outgoing>
      <bpmn:outgoing>Flow_P02_18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="N02_E4" name="退款駁回">
