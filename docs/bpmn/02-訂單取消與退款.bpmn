    <bpmn:startEvent id="N02_U1" name="提出取消申請">
      <bpmn:outgoing>Flow_P02_0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="N02_U2" name="提交取消申請與原因">
