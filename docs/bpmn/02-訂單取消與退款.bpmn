      <bpmn:outgoing>Flow_P02_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_P02_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N02_S4" name="訂單更新為 cancelled">
