      <bpmn:outgoing>Flow_P02_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_P02_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N02_S7b" name="通知會員取消結果">
