      <bpmn:outgoing>Flow_P02_1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="N02_S1" name="更新 cancellation_requested">
      <bpmn:incoming>Flow_P02_1</bpmn:incoming>
      <bpmn:outgoing>Flow_P02_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="N02_G1" name="是否符合取消期限">
      <bpmn:incoming>Flow_P02_2</bpmn:incoming>
      <bpmn:outgoing>Flow_P02_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_P02_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="N02_S2" name="通知不符合取消條件">
